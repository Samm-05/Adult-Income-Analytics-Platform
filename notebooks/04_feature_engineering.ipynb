   "id": "46024a28",
   "metadata": {},
   "outputs": [],
   "source": [
    "df[\"AgeGroup\"] = pd.cut(\n",
    "    df[\"age\"],\n",
    "    bins=[0,25,40,60,100],\n",
    "    labels=[\n",
    "        \"Young\",\n",
    "        \"Adult\",\n",
    "        \"Middle\",\n",
    "        \"Senior\"\n",
    "    ]\n",
    ")"
   ]
  }
